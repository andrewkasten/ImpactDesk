# Production environment variables for docker-compose.prod.yml
#
#   cp .env.prod.example .env.prod
#   # edit .env.prod
#   scp -i ~/.ssh/your-key.pem .env.prod ec2-user@34.211.57.59:/path/to/ImpactDesk/.env
#

# --- Django ---
# Generate a NEW key (do not reuse dev). Either of these works:
#   openssl rand -base64 50
#   docker compose -f docker-compose.prod.yml run --rm api python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_KEY=replace-me

# Hosts Django will accept requests for. Comma-separated.
ALLOWED_HOSTS=impactdesk.andrewkasten.cv

# Origins trusted for CSRF (admin form POSTs, etc). Must include scheme.
CSRF_TRUSTED_ORIGINS=https://impactdesk.andrewkasten.cv

# Tells Django to trust the X-Forwarded-Proto header from nginx so request.is_secure() works.
USE_PROXY_SSL_HEADER=True

# --- Postgres ---
# Use a NEW strong password for prod (do not reuse dev).
POSTGRES_DB=impactdesk
POSTGRES_USER=impactdesk
POSTGRES_PASSWORD=replace-me

# --- Frontend build args (baked into the React bundle at build time) ---
# Full origin so api calls go to https. Same-origin would also work (empty string),
# but the docker compose default substitutes a fallback if this is unset.
VITE_BASE_URL=https://impactdesk.andrewkasten.cv

# Google Maps API key for geocoding addresses in the development form.
# Without this, address lookup will fail on every save.
VITE_GEOCODE_KEY=replace-me
